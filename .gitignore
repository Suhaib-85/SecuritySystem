# --- 1. Node.js Backend ---
backend/node_modules/
backend/npm-debug.log
backend/yarn-error.log
backend/logs/
backend/pids/
backend/*.pid
backend/*.seed
backend/*.pid.lock

# --- 2. Environment Variables (CRITICAL) ---
# Never commit your database URI or JWT secrets
backend/.env
.env

# --- 3. Python Edge Device ---
edge_device/__pycache__/
edge_device/*.pyc
edge_device/venv/
edge_device/.venv/
edge_device/env/

# --- 4. AI Models & Large Assets ---
# You can comment out the next line if you WANT to commit the model (it's only 6MB)
edge_device/model/*.tflite
edge_device/model/*.zip

# --- 5. Media & Evidence ---
# Ignore heavy video files anywhere in the project
assets/*.mp4
*.mp4
*.h264
*.avi
evidence_*.mp4

# --- 6. Uploads & Temporary Storage ---
backend/uploads/*
!backend/uploads/.gitkeep
backend/test_tools/uploads/*
!backend/test_tools/uploads/.gitkeep

# --- 7. OS & Editor Files ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp