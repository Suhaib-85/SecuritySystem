# --- 1. Node.js Backend ---
backend/node_modules/
backend/npm-debug.log
backend/yarn-error.log
backend/*.pid
backend/*.seed
backend/*.pid.lock

# --- 2. Environment Variables (CRITICAL) ---
# Never commit your database URI or JWT secrets
*.env
*.local

# --- 3. Python Edge Device ---
__pycache__/
edge_device/*.pyc
edge_device/venv/
edge_device/.venv/

# --- 4. Documentation ---
docs/*.txt
docs/*.pdf

# --- 5. AI Models & Large Assets ---
# You can comment out the next line if you WANT to commit the model (it's only 6MB)
# edge_device/model/*.tflite
# edge_device/model/*.zip

# --- 6. Media & Evidence ---
# Ignore heavy video files anywhere in the project
*.mp4
*.jpg

# --- 7. Uploads & Temporary Storage ---
!**/.gitkeep
# Ignore local JSON metadata sidecar files on the edge device
edge_device/pending_uploads/*.json
edge_device/recordings/*.json

# --- 8. React Frontend (Vite) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# --- 9. OS & Editor Files ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
$RECYCLE.BIN/

# --- 10. Catch-all Log Files ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*